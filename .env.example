# Thai Election 2026 Data Pipeline — Environment Variables
# Copy this file to .env and fill in real values (never commit .env to git)

# Typhoon OCR API (Thai-specialized OCR — primary engine)
# Get your API key from: https://typhoon.openthai.ai
TYPHOON_OCR_API_KEY=your_typhoon_api_key_here
TYPHOON_OCR_BASE_URL=https://api.openthai.ai/v1

# Optional: Override source data directory (defaults to ../source/เขตเลือกตั้งที่ 2)
# SOURCE_DIR=/absolute/path/to/source/data
